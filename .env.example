# ── 应用基础 ──
APP_NAME=Enterprise KB
DEBUG=false
LOG_LEVEL=INFO

# ── LLM API（OpenAI 兼容接口） ──
# 支持: OpenAI / DeepSeek / 通义千问 / Ollama / 任意兼容接口
VLLM_API_URL=https://api.deepseek.com/v1
VLLM_API_KEY=sk-your-api-key-here
VLLM_MODEL_NAME=deepseek-chat
VLLM_MAX_TOKENS=2048
VLLM_TEMPERATURE=0.3
VLLM_TIMEOUT=60

# ── LlamaParse（文档解析） ──
# 可选，留空则使用本地 PDF 解析降级方案
LLAMA_CLOUD_API_KEY=

# ── Qdrant 向量数据库 ──
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_PREFER_GRPC=false
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=enterprise_kb
QDRANT_VECTOR_SIZE=1024
QDRANT_INDEX_THRESHOLD=10000

# ── 嵌入模型（BGE-M3） ──
EMBEDDING_MODEL_NAME=BAAI/bge-m3
EMBEDDING_MODEL_DEVICE=cpu
EMBEDDING_BATCH_SIZE=32
EMBEDDING_NORMALIZE=true

# ── 重排序模型（BGE-Reranker） ──
RERANKER_MODEL_NAME=BAAI/bge-reranker-v2-m3
RERANKER_MODEL_DEVICE=cpu
RERANKER_TOP_K=10

# ── 分块配置 ──
CHUNK_SIZE=512
CHUNK_OVERLAP=128
CHUNK_MARKDOWN_BY_HEADER=true

# ── HybridRAG 检索 ──
RETRIEVAL_VECTOR_TOP_K=20
RETRIEVAL_BM25_TOP_K=20
RETRIEVAL_RRF_K=60
RETRIEVAL_FINAL_TOP_K=10

# ── Wiki ──
WIKI_ROOT=./wiki
